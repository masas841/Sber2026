# GIGAvibe kiosk — только портрет (nanobanana / AITunnel)
PUBLIC_BASE_URL=auto

HOST=0.0.0.0
PORT=8765

GENERATOR_MODE=nanobanana
PRELOAD_MODEL_ON_STARTUP=false

NANOBANANA_BACKEND=aitunnel
AITUNNEL_API_KEY=sk-your-key-here
AITUNNEL_API_BASE_URL=https://api.aitunnel.ru/v1
NANOBANANA_MODEL=gemini-3.1-flash-image-preview
NANOBANANA_ASPECT_RATIO=9:16
NANOBANANA_IMAGE_SIZE=1K
NANOBANANA_STYLE=photoreal
# photoreal | toon | caricature | sharzh  (гротескный фестивальный шарж — caricature)

VIDEO_WIDTH=720
VIDEO_HEIGHT=1280

GUEST_AGE_CHILD_MAX=15
GUEST_AGE_SENIOR_MIN=55

KIOSK_AUTO_CAMERA=true
KIOSK_SMILE_CAPTURE=true
KIOSK_SMILE_THRESHOLD=0.42
KIOSK_SMILE_HOLD_FRAMES=12
KIOSK_SMILE_COOLDOWN_MS=8000
KIOSK_JPEG_QUALITY=0.96
KIOSK_TEST_MODE=false

OUTPUT_UPLOAD_ENABLED=false
PRINT_ENABLED=false

# HTTPS (опционально, после win-acme):
# USE_HTTPS=true
# SSL_CERTFILE=certs/cert.pem
# SSL_KEYFILE=certs/key.pem
