# Учётные данные Beget API для выпуска Let's Encrypt (DNS-01).
# Скопируйте в .env.ssl и заполните. Файл .env.ssl не коммитить.
#
# Beget → Настройки → Доступ по API → включить + задать пароль API.

BEGET_USERNAME=your_beget_login
BEGET_PASSWORD=your_beget_api_password

SSL_DOMAIN=slash.omelchak.com
SSL_EMAIL=admin@omelchak.com
