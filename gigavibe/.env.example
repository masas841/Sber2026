# auto — LAN IP; для продакшена: https://sberfest2026.ru:8765
PUBLIC_BASE_URL=auto

HF_TOKEN=hf_your_token_here

HOST=0.0.0.0
PORT=8765

# ltx | svd | liveportrait | ref_video | cinematic
# ref_video = референс-ролик как база + лицо с селфи (то, что нужно для IMG_9240)
GENERATOR_MODE=ref_video
PRELOAD_MODEL_ON_STARTUP=true

# LivePortrait (сначала: download_liveportrait.bat)
# Если мало места на диске: set LIVEPORTRAIT_USE_MAIN_VENV=1 перед bat
# LIVEPORTRAIT_USE_MAIN_VENV=true
# LIVEPORTRAIT_DRIVING_PATH=assets/driving/IMG_9240.MP4
# LIVEPORTRAIT_RANDOM_DRIVE=false
# LIVEPORTRAIT_DRIVING_OPTION=pose-friendly
# LIVEPORTRAIT_FLAG_CROP_DRIVING_VIDEO=true
# LIVEPORTRAIT_DRIVING_DIR=assets/driving
# LIVEPORTRAIT_RANDOM_DRIVE=true
# LIVEPORTRAIT_DRIVING_OPTION=expression-friendly
# LIVEPORTRAIT_FLAG_CROP_DRIVING_VIDEO=true

VIDEO_WIDTH=720
VIDEO_HEIGHT=1280
VIDEO_FPS=30
VIDEO_DURATION_SEC=10
VIDEO_ENCODE_CRF=18
VIDEO_ENCODE_PRESET=medium
REF_VIDEO_NO_UPSCALE=true
REF_VIDEO_USE_SOURCE_FPS=true
# inswapper = квадратная маска InsightFace (медленно). Production: inswapper_fast
REF_VIDEO_SWAP_ENGINE=inswapper_fast
# rope_v1 = GPU diff-paste + ONNX GFPGAN 512 в swap-цикле (как Rope)
REF_VIDEO_PIPELINE=rope_v1
REF_VIDEO_DIFF_AMOUNT=10
REF_VIDEO_RESTORE_ENGINE=onnx_512
REF_VIDEO_GFPGAN_ONNX_PATH=models/gfpgan/GFPGANv1.4.onnx
REF_VIDEO_GPU_PASTE=false
INSWAPPER_FAST_MODEL_PATH=models/inswapper_128.onnx
REF_VIDEO_SWAPPER_PATH=models/inswapper_128.onnx
REF_VIDEO_LEAN_DETECT=true
REF_VIDEO_THREADED_READ=true
REF_VIDEO_READ_QUEUE=8
REF_VIDEO_INLINE_RESTORE=true
REF_VIDEO_INLINE_RESTORE_WEIGHT=0.4
REF_VIDEO_FACE_RESTORE=true
# GFPGAN: 1 = каждый кадр (без артефактов stride); 2-3 = быстрее, но хуже на движении
REF_VIDEO_RESTORE_EVERY_N=1
REF_VIDEO_RESTORE_INTERPOLATE=true
REF_VIDEO_SKIP_FESTIVAL_FX=true
REF_VIDEO_SWAP_DEVICE_ID=0
REF_VIDEO_RESTORE_DEVICE_ID=0
REF_VIDEO_RESTORE_WORKERS=1
REF_VIDEO_DET_SIZE=512
# true на RTX 3090 (FARM): ~1.5–2× быстрее GFPGAN
REF_VIDEO_RESTORE_FP16=false
REF_VIDEO_SERIALIZE_JOBS=true
REF_VIDEO_SWAP_WORKERS=1
KIOSK_JPEG_QUALITY=0.96
# true — время генерации на экране результата (на площадке: false)
KIOSK_TEST_MODE=false

# Киоск: автокамера + снимок по улыбке
KIOSK_AUTO_CAMERA=true
KIOSK_SMILE_CAPTURE=true
KIOSK_SMILE_THRESHOLD=0.42
KIOSK_SMILE_HOLD_FRAMES=12
KIOSK_SMILE_COOLDOWN_MS=8000
KIOSK_FACE_MIN_SIZE=0.12

# Возраст: child ≤ GUEST_AGE_CHILD_MAX, senior ≥ GUEST_AGE_SENIOR_MIN (между — adult)
GUEST_AGE_CHILD_MAX=15
GUEST_AGE_SENIOR_MIN=55

# Ролики: assets/driving/manifest.json
# female/male × child | adult | senior × slim | medium | full

SVD_NUM_FRAMES=14
SVD_INFERENCE_STEPS=20

# LTX prompts (default from app/prompts.py per festival TZ PDF)
# LTX_PROMPT=
# LTX_NEGATIVE_PROMPT=

LTX_QUALITY=balanced
LTX_NUM_FRAMES=33
LTX_INFERENCE_STEPS=20
LTX_GUIDANCE_SCALE=3.5

FESTIVAL_COMPOSE_SCENE=false
FESTIVAL_ATMOSPHERE=true
FESTIVAL_FRAME=false

# Отправка готового портрета на внешний сервер (multipart POST) — по умолчанию выкл.
OUTPUT_UPLOAD_ENABLED=false
# Базовый URL photo_receiver (chunked upload + QR):
# OUTPUT_UPLOAD_URL=http://45.67.59.125:8767
# QR_PUBLIC_BASE_URL=http://45.67.59.125:8767
# OUTPUT_UPLOAD_MAX_RETRIES=5
# OUTPUT_UPLOAD_RETRY_DELAY_SEC=3
# OUTPUT_UPLOAD_API_KEY=
# OUTPUT_UPLOAD_AUTH=bearer
# OUTPUT_UPLOAD_TIMEOUT_SEC=60

# Печать на локальном принтере Windows (mspaint /pt) — по умолчанию выкл.
PRINT_ENABLED=false
# PRINT_ENABLED=true
# PRINT_PRINTER_NAME=
# PRINT_ONLY_IMAGES=true
# PRINT_AFTER_UPLOAD=true
# PRINT_WIDTH_MM=100
# PRINT_HEIGHT_MM=150
# PRINT_DPI=300
# OUTPUT_DISPATCH_FAIL_OPEN=true

# Optional updater for zip-installed kiosks. It preserves .env, venv/runtime, models,
# certs, dist and generated data while refreshing code from GitHub.
AUTO_UPDATE_FROM_GITHUB=false
UPDATE_REPO_REF=main
UPDATE_MANIFEST_URL=https://raw.githubusercontent.com/masas841/Sber2026/main/gigavibe/install/update-manifest.json
UPDATE_RAW_BASE_URL=https://raw.githubusercontent.com/masas841/Sber2026/main/gigavibe
UPDATE_REPO_ARCHIVE_URL=https://github.com/masas841/Sber2026/archive/refs/heads/main.zip
# For private repositories, create a fine-grained GitHub token with read-only Contents access.
# UPDATE_GITHUB_TOKEN=
